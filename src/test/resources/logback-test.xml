<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{call-id}] - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="ch.qos.logback" level="WARN"/>
    <logger name="org.apache.kafka" level="WARN"/>
    <logger name="org.flywaydb" level="WARN"/>
    <logger name="com.zaxxer" level="WARN"/>
    <logger name="io.ktor.auth.jwt" level="TRACE"/>
    <!-- Slå den på ved behov for logglinjer -->
    <logger name="no.nav.tiltakspenger.meldekort.clients" level="WARN"/>

    <logger name="team-logs-logger" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <!--
        Root på WARN for å unngå INFO-støy fra applikasjons-/ktor-tråder under Gradle-bygg.
        Logger fra spawnede tråder (coroutines, ktor test-server) lekker ut til Gradle-konsollen
        fordi Gradle bare fanger stdout per test-tråd.
        TODO jah: Dersom en test feiler ønsker vi mest mulig logg, mens når den kjører OK trenger vi ikke loggene (støtter gradle/junit dette?)
    -->
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
